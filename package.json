    "archiver": "^7.0.1",
    "chart.js": "^4.4.1",
    "dotenv": "^16.4.7",
    "express": "^4.21.1",
    "express-mysql-session": "^3.0.3",
    "express-session": "^1.18.1",
    "jose": "^5.9.6",
    "lucide": "^1.8.0",
    "mysql2": "^3.11.5",
    "node-cron": "^3.0.3",
    "nodemailer": "^6.9.16",
