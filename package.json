{
  "name": "panoptica",
  "version": "1.0.0",
  "description": "Multi-tenant M365 monitoring platform — replaces AdminDroid",
  "main": "src/server.js",
  "scripts": {
    "start": "node src/server.js",
    "dev": "NODE_ENV=development node src/server.js",
    "db:init": "node src/db/init-schema.js",
    "pm2:start": "pm2 start src/server.js --name panoptica",
    "pm2:stop": "pm2 stop panoptica",
    "pm2:restart": "pm2 restart panoptica",
    "pm2:logs": "pm2 logs panoptica"
  },
