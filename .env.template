# ═══════════════════════════════════════════════════════════════════
#  Panoptica365 — Environment Configuration
# ═══════════════════════════════════════════════════════════════════
#
# Copy this file to `.env` (in the same directory) and fill in the
# values. Never commit `.env` to git — it contains secrets.
#
# This file lists EVERY environment variable the application reads,
# grouped by subsystem. Required vars MUST be set or the app will
# refuse to start. Optional vars have safe defaults.
#
# Generated for Stage 2 container packaging — supersedes the older
# template that was missing several variables.
# ═══════════════════════════════════════════════════════════════════


# ─── Server ─────────────────────────────────────────────────────────
PORT=3000
NODE_ENV=production

# Timezone — used by node-cron schedules, email timestamps, and (most
# importantly) the MySQL session timezone. Eastern by default to match
# the existing date-comparison contract documented in
# feedback_mysql_utc_timestamp.md. Set to a different IANA tz only if
# your MSP operates outside Eastern.
TZ=America/Toronto


# ─── MySQL ──────────────────────────────────────────────────────────
# DB_HOST is `localhost` for native installs, `panoptica-db` inside
# the Docker Compose stack (compose substitutes the service name).
DB_HOST=localhost
DB_PORT=3306
DB_NAME=panoptica
DB_USER=panoptica
DB_PASS=YOUR_MYSQL_APP_PASSWORD

# Only used by the docker compose mysql:8.4 service on first boot
# (to set the root password and bootstrap the panoptica db + user).
# Ignored on native installs.
MYSQL_ROOT_PASSWORD=YOUR_MYSQL_ROOT_PASSWORD

# ─── MySQL pool + observability (Reliability P0, 2026-06-12) ────────
# All optional — the defaults shown are what the app uses when unset.
# DB_POOL_SIZE: max concurrent MySQL connections in the app's pool.
# DB_QUEUE_LIMIT: max requests allowed to WAIT for a connection before
#   failing fast (bounds memory under a DB stall; 0 = unbounded again).
# DB_ACQUIRE_TIMEOUT_MS: how long a request may wait for a pooled
#   connection before erroring (app-level deadline).
# DB_SLOW_QUERY_MS: queries slower than this are logged (SQL text only,
#   never parameter values).
#DB_POOL_SIZE=10
#DB_QUEUE_LIMIT=200
#DB_ACQUIRE_TIMEOUT_MS=15000
#DB_SLOW_QUERY_MS=2000

# ─── Outbound HTTP (Reliability P0, 2026-06-12) ─────────────────────
# Total deadline (headers + body) applied to every outbound HTTP request
# the app makes (Graph, Management API, Autotask, license server, …).
# UAL blob downloads internally use a higher 300s deadline.
#HTTP_TIMEOUT_MS=120000

# ─── AI-path resilience (Reliability 1.9, 2026-06-12) ───────────────
# AI_TIMEOUT_MS: per-call deadline on every Anthropic API call (the SDK
#   default is 10 minutes — far too long for a worker to hold). Slow paths
#   override internally (briefing 300s, reports 600s, key tests 30s).
# AI_DAILY_TOKEN_BUDGET: daily fuse for the AUTOMATED AI enrichment paths
#   (per-alert analysis, summaries, correlations). When the day's total
#   tokens cross this, enrichment pauses until midnight UTC, ONE system
#   alert is raised, and alerts keep firing without AI narratives.
#   0 = unlimited. Operator-initiated reports/chat are never blocked.
# AI_BREAKER_THRESHOLD / AI_BREAKER_COOLDOWN_MIN: skip AI enrichment after
#   N consecutive API failures, for M minutes, then self-reset.
#AI_TIMEOUT_MS=120000
#AI_DAILY_TOKEN_BUDGET=5000000
#AI_BREAKER_THRESHOLD=5
#AI_BREAKER_COOLDOWN_MIN=15

# ─── Release channel (Reliability 1.7, 2026-06-12) ──────────────────
# stable (default): follow the manifest's `latest` entry — what every
#   customer install should run.
# early: also consider the manifest's `early` entry when it's newer —
#   for the vendor's own instance and pilot installs that absorb a
#   release a few days before the fleet.
#UPDATE_CHANNEL=stable

# ─── Fleet telemetry (Reliability 1.8, 2026-06-12) ──────────────────
# Once a day, the install sends an instance-health summary to the
# license server so the vendor sees a sick install before you have to
# email support. EXACT field list (operational metadata only — customer
# and tenant data NEVER leaves this install): install fingerprint +
# license token (auth), app version, release channel, container/native,
# uptime, tenant COUNT, per-health-check states (ok/warn/crit), stale
# worker names, crash count, database size (GB), disk used (%).
# Set TELEMETRY_ENABLED=false to opt out entirely.
#TELEMETRY_ENABLED=true
#TELEMETRY_INTERVAL_H=24

# ─── Data retention windows, in days (Reliability P0, 2026-06-12) ───
# Enforced nightly at 03:30 by the retention worker. 0 disables cleanup
# for that table (kept forever). Alerts are NEVER auto-deleted — the
# alerts table is deliberately not governed by retention.
# Normally you do NOT edit these here: Settings → Data retention edits
# them in-app (writes these same keys + live-reloads, no restart needed).
#RETENTION_DEFENDER_INCIDENTS_DAYS=395
#RETENTION_IDENTITY_TIMELINE_DAYS=90
#RETENTION_HEATMAP_DAYS=730
#RETENTION_MESSAGE_CENTER_DAYS=365
#RETENTION_MSP_AUDIT_DAYS=730
#RETENTION_TENANT_CHANGES_DAYS=730

# metric_snapshots two-tier retention: full raw poll history is kept
# RETENTION_METRIC_RAW_DAYS whole days (the change-detection alerts only
# need the previous poll); beyond that, one compact end-of-day Secure Score
# row per tenant per day is kept RETENTION_METRIC_AGG_DAYS so the Posture
# Report's score trend works over any report period. Dashboards always read
# the separate metric_snapshots_latest table and are unaffected.
#RETENTION_METRIC_RAW_DAYS=7
#RETENTION_METRIC_AGG_DAYS=730


# ─── Microsoft Entra ID (operator authentication) ───────────────────
ENTRA_TENANT_ID=YOUR_TENANT_ID
ENTRA_CLIENT_ID=YOUR_APP_CLIENT_ID
ENTRA_CLIENT_SECRET=YOUR_APP_CLIENT_SECRET

# Where Microsoft redirects after login. Must match the redirect URI
# registered on your Entra app. The hostname half must equal the
# PANOPTICA365_HOSTNAME below.
ENTRA_REDIRECT_URI=https://YOUR_HOSTNAME/auth/callback
ENTRA_ADMIN_CONSENT_REDIRECT_URI=https://YOUR_HOSTNAME/auth/adminconsent/callback
ENTRA_TEAMS_DELEGATED_REDIRECT_URI=https://YOUR_HOSTNAME/auth/teams-delegated/callback


# ─── Operator role groups (Entra group Object IDs) ──────────────────
# Three-tier RBAC. If you only have one group, set it as
# ENTRA_AUTHORIZED_GROUP_ID and ENTRA_ADMIN_GROUP_ID; member + viewer
# can be left empty and everyone in that group becomes admin.
ENTRA_AUTHORIZED_GROUP_ID=YOUR_ADMIN_GROUP_ID
ENTRA_ADMIN_GROUP_ID=YOUR_ADMIN_GROUP_ID
ENTRA_MEMBER_GROUP_ID=YOUR_MEMBER_GROUP_ID
ENTRA_VIEWER_GROUP_ID=YOUR_VIEWER_GROUP_ID


# ─── Microsoft Graph (app-only certificate auth) ────────────────────
# Path to the PFX certificate bundle. Inside the container this maps
# to a bind-mounted certs/ directory. On native installs it lives at
# /opt/panoptica/certs/panoptica-graph.pfx.
GRAPH_CERT_PATH=/app/certs/panoptica-graph.pfx
GRAPH_CERT_THUMBPRINT=YOUR_CERT_SHA1_THUMBPRINT


# ─── PowerShell runner (EXO + SharePoint + Teams cmdlets) ───────────
# Binary path — Debian's pwsh apt package installs at /usr/bin/pwsh.
PWSH_BINARY=/usr/bin/pwsh
PWSH_TIMEOUT_MS=30000

# Security & Compliance PowerShell connection URI. Empty = let pwsh
# auto-detect from the tenant. Override for GCC High / DoD clouds.
PWSH_IPPS_URI=


# ─── Anthropic (Claude AI) ──────────────────────────────────────────
ANTHROPIC_API_KEY=YOUR_ANTHROPIC_API_KEY

# Optional — override the model used for tenant reports.
# Default: claude-sonnet-4-6. Set to a haiku/opus model for cost/quality
# tradeoffs.
REPORT_MODEL=

# Optional — override the Opus model id (used by the Quick Assessment
# report's deep gap analysis). Default: claude-opus-4-7.
OPUS_MODEL=

# When true (default), Haiku's per-alert analysis can downgrade alert
# severity if Microsoft's own error metadata says the event is benign
# (e.g., a 50097 device-auth interrupt). Only downgrades — never
# upgrades. Set to false to disable.
AI_CAN_ADJUST_SEVERITY=true

# Tenant digest cache TTL (milliseconds). Default 15 minutes.
AI_TENANT_DIGEST_CACHE_MS=900000


# ─── SMTP (email notifications via SMTP2GO or similar) ──────────────
SMTP_HOST=mail.smtp2go.com
SMTP_PORT=2525
SMTP_USER=YOUR_SMTP_USERNAME
SMTP_PASS=YOUR_SMTP_PASSWORD

# Display "From:" address on outbound alert + briefing emails.
SMTP_FROM=YOUR_FROM_ADDRESS


# ─── Notification routing ──────────────────────────────────────────
# Destination for PSA-routed alerts (Autotask, ConnectWise, HaloPSA,
# etc.). Empty = no PSA routing.
PSA_EMAIL=

# Template for the per-tenant attribution tag in email bodies (used by
# PSAs to match tickets to customer companies). ${PSA_NAME} is
# substituted from the tenant's psa_name field at send time.
PSA_ATTRIBUTION=//${PSA_NAME}//

# Comma-delimited list of operator email addresses that receive
# personal notifications + daily briefings.
NOTIFY_EMAILS=


# ─── Session secret ─────────────────────────────────────────────────
# Random 64-character hex string. Generate fresh on each install with:
#   openssl rand -hex 32
# This signs the session cookies — if it leaks, attackers can forge
# admin login. NEVER reuse across deployments. NEVER commit to git.
SESSION_SECRET=GENERATE_WITH_openssl_rand_-hex_32


# ─── License (Panoptica365 licensing — v0.1.8+) ─────────────────────
# Panoptica365 verifies its license offline using an embedded Ed25519
# public key. The license server (https://license.panoptica365.com)
# only issues + renews tokens; signature verification happens inside
# this app and survives license server outages.
#
# Boot REFUSES TO START without a valid LICENSE_TOKEN. To activate a
# fresh install:
#
#   1. Get your 24-char activation key from your MSP / from the
#      Panoptica365 license email.
#
#   2. On first boot, the app generates and persists a stable
#      PANOPTICA_INSTALL_FINGERPRINT (UUID v4) to this .env file
#      automatically. Note the value the app prints to the console.
#
#   3. Exchange the activation key for a license token:
#
#        curl -X POST https://license.panoptica365.com/api/v1/activate \
#          -H "Content-Type: application/json" \
#          -d '{"activation_key":"YOUR-KEY","fingerprint":"YOUR-FINGERPRINT"}'
#
#   4. Copy the `token` field from the response and set LICENSE_TOKEN
#      below to that value. Restart Panoptica365.
#
# A copy of the verified token is also mirrored to
#   data/state/license-cache.json
# so that an accidental wipe of LICENSE_TOKEN here won't take the
# install down — the cache is the boot fallback when the env var is
# absent. Cache is rewritten on every successful boot + every weekly
# refresh, so it stays current.
#
# Stage 4 installer (panoptica365/installer) automates all of this.
LICENSE_TOKEN=
PANOPTICA_INSTALL_FINGERPRINT=


# ─── Daily summary email ────────────────────────────────────────────
# Minimum severity threshold for inclusion in the 6 AM briefing.
# Valid: info | low | medium | high | severe. Default 'info' includes
# everything; dial up to 'medium' or 'high' as your fleet grows.
BRIEFING_MIN_SEVERITY=info


# ─── Monthly export (Custodia Menses integration) ───────────────────
# Directory where monthly JSON exports are written on the 15th.
# Inside the container, set to a path under /app that's bind-mounted
# to data/uploads/exports/ for host-side access.
EXPORT_DIR=/app/exports


# ─── Report branding ────────────────────────────────────────────────
# MSP name shown on customer-facing PDFs ("Prepared by ___").
MSP_NAME=

# Default license tier shown to AI when no per-tenant license info is
# available. Most MSPs default to Business Premium.
DEFAULT_LICENSE_TIER=Microsoft 365 Business Premium

# Whether the "via Panoptica365" platform tail appears on report
# footers. Default true. Set to false for white-label usage.
REPORT_PLATFORM_ATTRIBUTION=true


# ═══════════════════════════════════════════════════════════════════
# ─── Container deployment (Stage 2+ only — ignored on native installs)
# ═══════════════════════════════════════════════════════════════════

# Public hostname Caddy listens on. Must match the Entra redirect URI
# host part and your DNS A record. For production deployments, set this
# to your real hostname — Caddy will auto-issue a Let's Encrypt cert.
PANOPTICA365_HOSTNAME=YOUR_HOSTNAME

# Email Caddy registers with Let's Encrypt for cert-expiry warnings.
LETSENCRYPT_EMAIL=YOUR_EMAIL

# OPTIONAL — override the Caddy site listen address. If unset, Caddy uses
# PANOPTICA365_HOSTNAME (the normal production path with auto Let's
# Encrypt). For HTTP-only local testing on a private IP, set this to
# `:80` — Caddy will bind port 80 without trying to issue any TLS cert,
# sidestepping the IP-address + internal-CA quirk that breaks browser
# TLS handshakes. Leave commented out / unset for production.
# CADDY_LISTEN=:80

# Base URL used in email body links (alert emails, daily briefings).
# Should match PANOPTICA365_HOSTNAME prefixed with https://.
# Will be wired into notifier.js + morning-briefing.js in push #3.
PANOPTICA_BASE_URL=https://YOUR_HOSTNAME

# (Recommended) Tenant GUID of the MSP's own tenant. Used to select which
# tenant gets the "executive summary" daily briefing in multi-tenant
# deployments. SET THIS on every install: when unset the code falls back to a
# name-LIKE lookup that only matches the original developer's tenant, then to
# tenant_id=1. Setting it explicitly is the brand-neutral, correct choice.
MSP_TENANT_GUID=
