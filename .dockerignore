# ═══════════════════════════════════════════════════════════════════
#  Panoptica365 — Docker build context exclusions
# ═══════════════════════════════════════════════════════════════════
#
# Anything listed here is NOT sent to the Docker daemon during build,
# so it never ends up in the image. Two goals:
#   1. Keep image small + builds fast (no node_modules, no .git, no
#      accumulated dev cruft).
#   2. Prevent secrets / customer data from leaking into images that
#      might later be pushed to GHCR.
# ═══════════════════════════════════════════════════════════════════

# ─── Secrets — NEVER ship ──────────────────────────────────────────
.env
.env.local
.env.*.local
*.pfx
*.cer
*.crt
*.key
*.thumbprint

# ─── Git ───────────────────────────────────────────────────────────
.git
.gitignore
.gitattributes

# ─── Node ──────────────────────────────────────────────────────────
# Rebuilt fresh inside the container — don't ship the host's version.
node_modules
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# ─── Python ────────────────────────────────────────────────────────
# venv is recreated inside the container at /app/venv.
venv
__pycache__
*.pyc
*.pyo

# ─── Runtime / state directories (bind-mounted at runtime, never baked in)
data
certs
logs
backups
exports
snapshots

# ─── Dev / docs / planning (excluded from git anyway, double-safety)
dev
Documentation
claude api usage
i18n-snapshot-log.md
DR-RESTORE.md
panoptica-setup.sh
panoptica_backup.sh
ps-setup.sh
# Note: legacy schema-*.sql files used to live at the repo root; they
# now live under dev/Panoptica/legacy-schema/ which is already excluded
# by the `dev` line above. The schema-*.sql exclusion that used to be
# here is no longer needed.
backups
*.log

# Markdown handoff / planning files — not for shipped images.
HANDOFF_*.md
RUNBOOK*.md
*HANDOFF*.md

# ─── OS / IDE junk ────────────────────────────────────────────────
.DS_Store
._*
.smbdelete*
.vscode
.idea
*.swp
*.swo
Thumbs.db
ehthumbs.db

# ─── Disk-image-style files (large, never wanted in builds) ───────
*.vhd
*.vhdx
*.iso
*.tar.gz
*.zip

# ─── Compose + Docker tooling — not needed inside the app image ───
docker-compose.yml
docker-compose.*.yml
Dockerfile
.dockerignore
Caddyfile

# ─── Graphics intended for marketing site, not the app ────────────
"Login background.png"
"Login background.webp"
"Panoptica365 Logo-v2.png"
"Panoptica365 Report Cover.png"
graphics
"Links to consoles.txt"

# Updater-managed image pin (host runtime file; keep out of the image build context)
docker-compose.override.yml
